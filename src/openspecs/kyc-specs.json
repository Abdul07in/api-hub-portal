        "/checkkyc/verifyPan": {
            "post": {
                "tags": [
                    "KYC Verification"
                ],
                "summary": "Verify PAN using KYC Service",
                "description": "Verifies PAN and retrieves KYC data from external KYC service after validating client credentials. Returns encrypted response with KYC status (Valid/On Hold/Not Available). Requires Authorization header with Bearer token.",
                "operationId": "verifyPan",
                "parameters": [
                    {
                        "name": "ClientID",
                        "in": "header",
                        "description": "Client ID for authentication",
                        "required": true
                    },
                    {
                        "name": "RequestID",
                        "in": "header",
                        "description": "Unique request identifier",
                        "required": true
                    },
                    {
                        "name": "ClientIP",
                        "in": "header",
                        "description": "Client IP address",
                        "required": true
                    },
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "Bearer token for authentication",
                        "required": true,
                        "example": "Bearer eyJhbGciOiJ..."
                    }
                ],
                "requestBody": {
                    "description": "Request body containing PAN number to verify",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EncryptedContentDto"
                            }
                        }
                    }
                },
                "responses": {
                    "503": {
                        "description": "External KYC service unavailable",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "PAN verification successful - returns KYC data based on status",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - invalid client credentials or missing/invalid Bearer token",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error or external KYC service error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request - missing or invalid PAN number",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    }
                }
            }
        },
