    "paths": {
        "/nsdl/nsdl-pan-verification": {
            "post": {
                "tags": [
                    "NSDL PAN Verification"
                ],
                "summary": "Verify PAN via NSDL",
                "description": "Verifies PAN details (name, DOB, father name) against NSDL records via CAMS service. Request body must be encrypted. Requires Authorization header with Bearer token.",
                "operationId": "verifyNsdlPan",
                "parameters": [
                    {
                        "name": "ClientID",
                        "in": "header",
                        "description": "Client ID for authentication",
                        "required": true
                    },
                    {
                        "name": "RequestID",
                        "in": "header",
                        "description": "Unique request identifier",
                        "required": true
                    },
                    {
                        "name": "ClientIP",
                        "in": "header",
                        "description": "Client IP address",
                        "required": true
                    },
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "Bearer token for authentication",
                        "required": true,
                        "example": "Bearer eyJhbGciOiJ..."
                    }
                ],
                "requestBody": {
                    "description": "Encrypted request body containing PAN, name, fathername, dob",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EncryptedContentDto"
                            }
                        }
                    }
                },
                "responses": {
                    "503": {
                        "description": "NSDL service unavailable",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - invalid credentials or Bearer token",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "PAN verification successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "415": {
                        "description": "Unsupported Media Type - Content-Type must be application/json",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request - validation failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    }
                }
            }
        },
