        {
            "bearerAuth": []
        }
    ],
    "tags": [
        {
            "name": "FATCA Details",
            "description": "APIs for FATCA details operations"
        },
        {
            "name": "Tax Status",
            "description": "APIs for retrieving tax status information"
        },
        {
            "name": "KYC Verification",
            "description": "APIs for KYC verification operations"
