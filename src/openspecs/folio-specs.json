        "/statement/v2/getSOA": {
            "post": {
                "tags": [
                    "account-statement-controller"
                ],
                "summary": "Download Statement of Account",
                "description": "Downloads account statement after validating client credentials. The request body must be encrypted. Requires Authorization header with Bearer token.",
                "operationId": "getStatementV2",
                "parameters": [
                    {
                        "name": "ClientID",
                        "in": "header",
                        "description": "Client ID for authentication",
                        "required": true
                    },
                    {
                        "name": "RequestID",
                        "in": "header",
                        "description": "Unique request identifier",
                        "required": true
                    },
                    {
                        "name": "ClientIP",
                        "in": "header",
                        "description": "Client IP address",
                        "required": true
                    },
                    {
                        "name": "Authorization",
                        "in": "header",
                        "description": "Bearer token for authentication",
                        "required": true,
                        "example": "Bearer eyJhbGciOiJ..."
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/EncryptedContentDto"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "415": {
                        "description": "Unsupported Media Type - Content-Type must be application/json",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "200": {
                        "description": "Statement retrieved successfully",
                        "content": {
                            "application/json": {}
                        }
                    },
                    "500": {
                        "description": "Internal server error or external service error",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request format, missing required fields, or validation failures",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - invalid client credentials or missing/invalid Bearer token",
                        "content": {
                            "*/*": {
                                "schema": {
                                    "$ref": "#/components/schemas/EncryptedContentDto"
                                }
                            }
                        }
                    }
                }
            }
        },
